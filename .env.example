# ─────────────────────────────────────────────────────────────────────────────
# Inside Out Multi-Agent System — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Jan AI (local LLM server) ────────────────────────────────────────────────
# Download Jan AI from https://jan.ai and start the local server.
JAN_BASE_URL=http://127.0.0.1:1337/v1
JAN_API_KEY=your_jan_api_key_here
JAN_MODEL_NAME=Meta-Llama-3_1-8B-Instruct_Q4_K_M

# ── LLM generation settings ──────────────────────────────────────────────────
MAX_TOKENS=500
TEMPERATURE=0.9

# ── Weather API (https://www.weatherapi.com/) ────────────────────────────────
# Sign up for a free key at https://www.weatherapi.com/signup.aspx
WEATHER_API_KEY=your_weather_api_key_here
WEATHER_API_TIMEOUT=10
WEATHER_API_MAX_RETRIES=3
